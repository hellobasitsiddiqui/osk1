{
  "hosting": {
    "site": "openskeleton-one",
    "public": "web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "web/Dockerfile",
      "web/.dockerignore",
      "web/nginx.conf",
      "web/README.md"
    ],
    "rewrites": [
      {
        "source": "/status",
        "destination": "/status.html"
      },
      {
        "source": "/ops",
        "destination": "/ops.html"
      },
      {
        "source": "/help",
        "destination": "/help.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/config.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
