# GCP project configuration for OpenSkeleton (OSK-36). These are non-secret
# identifiers (project ids/numbers are not credentials); real secrets live in
# Secret Manager (OSK-15/OSK-25). Deploy tooling reads these instead of
# hardcoding — keep this the single source of truth for the cloud target.
#
# This project is DELIBERATELY separate from any other project (e.g. teammarhaba);
# every gcloud/deploy command targets GCP_PROJECT_ID explicitly.
GCP_PROJECT_ID=openskeleton-one
GCP_PROJECT_NUMBER=476227744481
GCP_REGION=europe-west2
GCP_ORG_ID=103553953969
FIREBASE_HOSTING_SITE=openskeleton-one

# Enabled APIs: run, sqladmin, firebasehosting, secretmanager, artifactregistry,
# firebase, identitytoolkit. Firebase added (state ACTIVE). Auth providers are
# configured via the Identity Platform admin API (Email/Password pending).

# Keyless CI deploy auth (OSK-42) — GitHub Actions federates via Workload Identity
# (OIDC), no service-account key. The deploy SA holds least-privilege roles
# (run.admin, artifactregistry.writer, iam.serviceAccountUser, firebasehosting.admin,
# secretmanager.secretAccessor, cloudsql.client), and the WIF provider trusts ONLY
# the repo hellobasitsiddiqui/osk1.
GCP_DEPLOY_SA=gh-deployer@openskeleton-one.iam.gserviceaccount.com
GCP_WIF_PROVIDER=projects/476227744481/locations/global/workloadIdentityPools/github/providers/github-provider
