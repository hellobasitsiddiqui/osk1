<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- OSK-152 — device location (@capacitor/geolocation).
         FINE = GPS-grade precise location; COARSE = network/approximate. Both are
         declared because the runtime request (web/geolocation.js) asks for precise
         location, but on Android 12+ the user may grant only "Approximate", in which
         case only COARSE is honoured — declaring both lets the plugin degrade to the
         coarse fix the user allowed instead of failing. These are DANGEROUS
         (runtime) permissions: declaring them here only makes them requestable; the
         actual grant is prompted at runtime by Geolocation.requestPermissions().
         The web fallback (browser navigator.geolocation) never reads this manifest. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- OSK-150 — push notifications (@capacitor/push-notifications).
         POST_NOTIFICATIONS is the Android 13+ (API 33+) RUNTIME permission required to
         show notifications at all; the plugin's requestPermissions() (driven by
         web/push-client.js) prompts for it. Declaring it here only makes it requestable
         — the actual grant is a runtime prompt; on Android 12 and below there is no
         prompt and it is granted implicitly. The plugin's own manifest additionally
         merges in the FirebaseMessagingService, so no <service> is declared here.

         NOTE — live delivery is gated on OSK-165 (HUMAN): actually receiving a push also
         needs Firebase Cloud Messaging enabled and android/app/google-services.json
         present (that file is a per-project config the human adds; it is deliberately NOT
         committed). android/app/build.gradle applies the google-services plugin ONLY when
         that JSON exists, so the APK still builds without it and the client degrades
         gracefully (a registrationError, handled by push-client.js) until OSK-165 lands.
         The web fallback path (plain browser) never reads this manifest. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
