# .env.example — template of every environment variable the app reads.
#
# What: a checked-in, non-secret reference of all runtime configuration keys.
# Why: keeps config discoverable in one place without ever committing real
# values. Copy to `.env` (git-ignored) and fill in real values locally, or set
# these in your platform's secret store / environment for deployed instances.
#
# SECURITY: this file must contain PLACEHOLDERS ONLY — never real credentials.
# The root .gitignore blocks `.env` so your filled-in copy is not committed.
#
# ------------------------------------------------------------------------------
# TWO CONTRACTS, ONE FILE — read this before editing.
#
#   DEV / docker-compose (local): the base + dev profiles ship local-safe defaults,
#   so the app boots with zero config. Locally the datasource is built from DB_URL
#   (a plain localhost/compose JDBC URL). Use `scripts/dev-setup.sh` to generate a
#   working local `.env`; do NOT `cp .env.example .env` (the prod-shaped vars would
#   leave DB_PASSWORD blank and compose would abort — TM-127).
#
#   PROD (Cloud Run): the prod profile deliberately DROPS those defaults, so EVERY
#   var in the prod contract must be supplied explicitly or the app fails fast at
#   boot — the OSK-25 fail-loud guarantee (AppProperties @NotBlank + bare ${VAR}
#   placeholders in application-prod.yml). Prod does NOT use DB_URL: it connects to
#   Cloud SQL through the socket factory built from INSTANCE_CONNECTION_NAME +
#   DB_NAME, with DB_PASSWORD injected from Secret Manager (never a committed value).
#
# The full prod var set → source (plain Cloud Run env var | Secret Manager | derived)
# and the keyless-WIF identity model are documented in `infra/secrets-and-env.md`
# (OSK-15); the deploy that sets them is `.github/workflows/deploy.yml` (OSK-47).
#
# The prod contract (all supplied by the deploy — none are GitHub Actions secrets):
#   SPRING_PROFILES_ACTIVE, INSTANCE_CONNECTION_NAME, DB_NAME, DB_USERNAME,
#   DB_PASSWORD (Secret Manager), APP_ENVIRONMENT_NAME, APP_PUBLIC_BASE_URL,
#   GOOGLE_CLOUD_PROJECT.
# ------------------------------------------------------------------------------

# --- Runtime / server ----------------------------------------------------------
# Which Spring profile(s) to activate: dev | test | prod (comma-separated).
# Unset => base defaults only (fine for a zero-setup local run and for tests).
# PROD: must be `prod` — the deploy sets SPRING_PROFILES_ACTIVE=prod.
SPRING_PROFILES_ACTIVE=dev

# HTTP port the backend binds. Cloud Run injects this; defaults to 8080 locally.
PORT=8080

# --- Application (app.*) --------------------------------------------------------
# Human-readable environment label surfaced via /actuator/info. Required in prod
# (@NotBlank — blank/unset fails boot). Prod deploy sets it to `prod`.
APP_ENVIRONMENT_NAME=local

# Public base URL the service is reached at (used for absolute links). Required in
# prod (@NotBlank). In prod the deploy sets this to the Cloud Run service URL.
APP_PUBLIC_BASE_URL=http://localhost:8080

# --- Google Cloud (prod) -------------------------------------------------------
# GCP project id, used as the Cloud Monitoring metrics project (application-prod.yml,
# OSK-55). The prod deploy sets it; unset locally (metrics export is off in dev/test).
# NOT a secret — a project id is a plain identifier, not a credential.
GOOGLE_CLOUD_PROJECT=

# Firebase project whose ID tokens the backend verifies (OSK-28). Defaults to
# openskeleton-one; credentials come from Application Default Credentials (ADC) — the
# Cloud Run runtime SA in prod, or `gcloud auth application-default login` locally.
# NO service-account key is ever committed. Override only if you need a different one.
FIREBASE_PROJECT_ID=openskeleton-one

# --- API rate limiting (app.rate-limit.*, OSK-63) ------------------------------
# Per-client token-bucket rate limit on /api/** (abuse/DoS protection). Keyed by the
# authenticated Firebase uid when present, else the client IP. /health, /actuator/**
# and readiness are exempt. All optional — the defaults below apply when unset.
#
# Master on/off switch for the limiter (true|false).
APP_RATE_LIMIT_ENABLED=true
# Bucket size = max burst of requests served back-to-back before the refill rate caps it.
APP_RATE_LIMIT_CAPACITY=100
# Tokens (requests) replenished every APP_RATE_LIMIT_REFILL_PERIOD.
APP_RATE_LIMIT_REFILL_TOKENS=100
# Refill interval (Spring duration, e.g. 1m, 30s, 1h). Sustained rate = refill-tokens / this.
APP_RATE_LIMIT_REFILL_PERIOD=1m

# --- Auth resilience (OSK-65) --------------------------------------------------
# Graceful degradation for the outbound Firebase token-verification call is
# configured in backend/src/main/resources/application.yml under `resilience4j.*`
# (TimeLimiter + Retry + CircuitBreaker: a slow/failing/tripped verify fails fast as
# a degraded 503, an invalid token stays a 401). The per-attempt verification
# timeout is the one knob commonly tuned per environment; override it here (a Spring
# duration, e.g. 2s, 500ms). All other knobs (retry attempts/backoff, breaker
# thresholds) live in application.yml.
AUTH_VERIFY_TIMEOUT=2s

# --- Database: PROD contract (Cloud Run + Cloud SQL via socket factory) ---------
# Prod connects to Cloud SQL over the socket-factory connector — no public IP and
# NO DB_URL. application-prod.yml builds the JDBC URL from these two vars:
#   jdbc:postgresql:///${DB_NAME}?cloudSqlInstance=${INSTANCE_CONNECTION_NAME}&socketFactory=...
# The deploy passes them as plain Cloud Run env vars (see deploy.yml / gcp.env).
# Neither is a secret. Both are IGNORED by the dev profile (which uses DB_URL below).
#
# Cloud SQL instance connection name (project:region:instance). Required in prod
# (bare ${VAR}, no default — boot fails if unset).
INSTANCE_CONNECTION_NAME=openskeleton-one:europe-west2:osk-pg
# Database name on that instance. Prod default: osk (the deploy sets it explicitly).
DB_NAME=osk

# --- Database: credentials (used by BOTH dev and prod) -------------------------
# Database username. Prod default: app (the deploy sets it explicitly).
DB_USERNAME=osk1
# Database password. Required in prod (bare ${VAR}, no default) — the ONLY runtime
# secret. In prod it is injected from Secret Manager (secret `osk-db-app-password`)
# via the deploy's --set-secrets — it is NOT a GitHub Actions secret and is NEVER
# committed or echoed. Placeholder only here; NEVER put a real value in this file.
DB_PASSWORD=changeme

# --- Database: DEV / docker-compose ONLY (local) -------------------------------
# Plain localhost/compose JDBC URL used by the dev profile + docker-compose. Prod
# IGNORES this entirely (prod builds the URL from the socket-factory vars above).
# Kept here so the local/compose path stays zero-secret and self-contained.
DB_URL=jdbc:postgresql://localhost:5432/osk1
